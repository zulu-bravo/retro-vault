RECREATE Object retro_vote__c (
    label('Vote'),
    label_plural('Votes'),
    active(true),
    in_menu(true),
    audit(false),
    description('Upvote on a feedback item, one per user per item')
);

ALTER Object retro_vote__c (
    add Field feedback_item__c (
        label('Feedback Item'),
        type('ObjectReference'),
        object('retro_feedback__c'),
        relationship_type('reference'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_vote__c (
    add Field voter__c (
        label('Voter'),
        type('ObjectReference'),
        object('user__sys'),
        relationship_type('reference'),
        active(true),
        required(true),
        list_column(false)
    )
);
