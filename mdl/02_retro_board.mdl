RECREATE Object retro_board__c (
    label('Retro Board'),
    label_plural('Retro Boards'),
    active(true),
    in_menu(true),
    audit(false),
    description('A retrospective session board')
);

ALTER Object retro_board__c (
    add Field facilitator__c (
        label('Facilitator'),
        type('ObjectReference'),
        object('user__sys'),
        relationship_type('reference'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_board__c (
    add Field team__c (
        label('Team'),
        type('ObjectReference'),
        object('retro_team__c'),
        relationship_type('reference'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_board__c (
    add Field release_tag__c (
        label('Release Tag'),
        type('String'),
        max_length(100),
        active(true),
        required(false),
        list_column(false)
    )
);

ALTER Object retro_board__c (
    add Field board_date__c (
        label('Board Date'),
        type('Date'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_board__c (
    add Field status__c (
        label('Status'),
        type('Picklist'),
        picklist('Picklist.board_status__c'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_board__c (
    add Field features__c (
        label('Features'),
        type('String'),
        max_length(1500),
        active(true),
        required(false),
        list_column(false)
    )
);
