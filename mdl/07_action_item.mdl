RECREATE Object retro_action__c (
    label('Action Item'),
    label_plural('Action Items'),
    active(true),
    in_menu(true),
    audit(false),
    description('Action item created from a retrospective')
);

ALTER Object retro_action__c (
    add Field retro_board__c (
        label('Retro Board'),
        type('ObjectReference'),
        object('retro_board__c'),
        relationship_type('reference'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_action__c (
    add Field owner__c (
        label('Owner'),
        type('ObjectReference'),
        object('user__sys'),
        relationship_type('reference'),
        active(true),
        required(false),
        list_column(false)
    )
);

ALTER Object retro_action__c (
    add Field status__c (
        label('Status'),
        type('Picklist'),
        picklist('Picklist.action_status__c'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_action__c (
    add Field due_date__c (
        label('Due Date'),
        type('Date'),
        active(true),
        required(false),
        list_column(false)
    )
);

ALTER Object retro_action__c (
    add Field completed_at__c (
        label('Completed At'),
        type('DateTime'),
        active(true),
        required(false),
        list_column(false)
    )
);

ALTER Object retro_action__c (
    add Field assignee__c (
        label('Assignee'),
        type('ObjectReference'),
        object('user__sys'),
        relationship_type('reference'),
        active(true),
        required(false),
        list_column(false)
    )
);

ALTER Object retro_action__c (
    add Field group__c (
        label('Group'),
        type('String'),
        max_length(50),
