RECREATE Object retro_release__c (
    label('Release'),
    label_plural('Releases'),
    active(true),
    in_menu(true),
    audit(false),
    description('A software release used to group retro boards across teams')
);

ALTER Object retro_release__c (
    add Field features__c (
        label('Features'),
        type('String'),
        max_length(1500),
        active(true),
        required(false),
        list_column(false)
    )
);
