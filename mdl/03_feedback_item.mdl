RECREATE Object retro_feedback__c (
    label('Feedback Item'),
    label_plural('Feedback Items'),
    active(true),
    in_menu(true),
    audit(false),
    description('Individual feedback entry on a retro board')
);

ALTER Object retro_feedback__c (
    add Field retro_board__c (
        label('Retro Board'),
        type('ObjectReference'),
        object('retro_board__c'),
        relationship_type('reference'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_feedback__c (
    add Field author__c (
        label('Author'),
        type('ObjectReference'),
        object('user__sys'),
        relationship_type('reference'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_feedback__c (
    add Field category__c (
        label('Category'),
        type('Picklist'),
        picklist('Picklist.feedback_category__c'),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_feedback__c (
    add Field content__c (
        label('Content'),
        type('String'),
        max_length(1500),
        active(true),
        required(true),
        list_column(false)
    )
);

ALTER Object retro_feedback__c (
    add Field theme__c (
        label('Theme'),
        type('Picklist'),
        picklist('Picklist.ai_theme__c'),
        active(true),
        required(false),
        list_column(false)
    )
);

ALTER Object retro_feedback__c (
    add Field feature__c (
        label('Feature'),
        type('String'),
        max_length(200),
        active(true),
        required(false),
        list_column(false)
    )
);

ALTER Object retro_feedback__c (
    add Field vote_count__c (
        label('Vote Count'),
        type('Number'),
        min_value(0),
        max_value(9999),
        active(true),
        required(false),
        list_column(false)
    )
);
