/*
 * RetroVault - Action Item Object
 * Depends on: 00_picklists.mdl, 02_retro_board.mdl
 * User references use built-in user__sys object.
 */

RECREATE Object action_item__c (
    label('Action Item'),
    label_plural('Action Items'),
    active(true),
    description('Action item created from a retrospective'),

    Objectfield name__v (
        label('Title'),
        type('String'),
        active(true),
        required(true)
    ),

    Objectfield retro_board__c (
        label('Retro Board'),
        type('ObjectReference'),
        active(true),
        required(true),
        object('retro_board__c'),
        relationship_type('reference')
    ),

    Objectfield owner__c (
        label('Owner'),
        type('ObjectReference'),
        active(true),
        object('user__sys'),
        relationship_type('reference')
    ),

    Objectfield status__c (
        label('Status'),
        type('Picklist'),
        active(true),
        required(true),
        picklist('action_status__c')
    ),

    Objectfield due_date__c (
        label('Due Date'),
        type('Date'),
        active(true)
    ),

    Objectfield completed_at__c (
        label('Completed At'),
        type('DateTime'),
        active(true)
    )
);
